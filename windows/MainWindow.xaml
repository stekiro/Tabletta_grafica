<Window x:Class="DrawTabletPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DrawTablet PC - Ricezione in tempo reale"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="700"
        Background="#263238">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="#37474F" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🎨 DrawTablet PC"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10"
                             Fill="#EF5350" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="In attesa del tablet..."
                               Foreground="#B0BEC5" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="3" x:Name="BtnClear" Content="🗑 Pulisci"
                        Margin="12,6,6,6" Padding="12,0"
                        Background="#EF5350" Foreground="White" BorderThickness="0"
                        Click="BtnClear_Click" Cursor="Hand"/>

                <Button Grid.Column="4" x:Name="BtnSave" Content="💾 Salva PNG"
                        Margin="6,6,0,6" Padding="12,0"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Click="BtnSave_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Canvas area -->
        <Border Grid.Row="1" Margin="12" Background="White"
                BorderBrush="#546E7A" BorderThickness="1">
            <Canvas x:Name="DrawCanvas" Background="White"
                    ClipToBounds="True"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#1C2832" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="InfoText"
                           Text="Avvia l'app Android e inserisci l'IP di questo PC"
                           Foreground="#607D8B" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="IpText" Grid.Column="1"
                           Foreground="#607D8B" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
